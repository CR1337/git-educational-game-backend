#!/bin/bash

bin/running
if [ $? -ne 1 ]; then
    echo "Already running."
    exit
fi

INTERACTIVE=0

while getopts ":i" opt; do
  case $opt in
    i)
      INTERACTIVE=1
      ;;
    *)
      echo "Usage: $0 [-i]"
      exit 1
      ;;
  esac
done

if [ "$INTERACTIVE" -eq 1 ]; then
{{ container_runtime }} compose up
else
{{ container_runtime }} compose up -d
fi
