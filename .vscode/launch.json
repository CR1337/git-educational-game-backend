{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Orchestrator",
      "type": "debugpy",
      "request": "launch",
      "program": "orchestrator.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/services/api"
    },
    {
      "name": "Debug Api",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "api:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8080"
      ],
      "jinja": true,
      "justMyCode": true,
      "cwd": "${workspaceFolder}/services/api"
    }
  ]
}